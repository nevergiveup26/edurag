.uploads/
logs/
sample_data/

# Docker data (volume mounts)
docker/

# Frontend (built separately)
frontend/node_modules/

# Tests (not needed in production image)
tests/

# Documentation
docs/
*.md

# Scripts (one-off utilities)
scripts/

# Performance testing
k6-master/

# Claude Code config
.claude/

# Browser automation cache
.browsers/

# Code review artifacts
code-review/

# Standalone Milvus
milvus/

# CI/CD
.github/

tutorial/*.md